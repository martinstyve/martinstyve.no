---
import Layout from "../../components/Layout.astro";
---

<Layout title="NSA - Running Pace Analysis">
  <div class="project-wrapper">
    <section class="project-header">
      <h1>NSA - Running Pace Analysis</h1>
      <div class="project-meta">
        <span class="course">Advanced Functional Programming (INF221)</span>
        <span class="date">Spring 2026</span>
      </div>
    </section>

    <section class="project-content">
      <div class="content-grid">
        <div class="image-section">
          <img 
            src="/project_photos/nsa.png" 
            alt="NSA Running Pace Analysis" 
            class="project-image" 
          />
        </div>
        
        <div class="description-section">
          <h2>Project Overview</h2>
          <p>
            NSA is a Haskell web application for running pace analysis and guidance. The application takes a race time and race distance as input and calculates equivalent race times for standard race distances, as well as interval pace ranges for "Norwegian Singles Approach" style workouts. This project was created as an assignment for Advanced Functional Programming at UiB and is actively used for personal training planning.
          </p>
          
          <div class="tech-stack">
            <h3>Technologies Used</h3>
            <div class="tech-tags">
              <span class="tag">Haskell</span>
              <span class="tag">Web Development</span>
              <span class="tag">Functional Programming</span>
            </div>
          </div>

          <div class="project-links">
            <a href="https://nsa.martinstyve.no" target="_blank" class="link-button">
              <span>Visit Live Site</span>
            </a>
            <a href="https://github.com/martinstyve/nsa" target="_blank" class="link-button">
              <img src="/logos/GitHub_logo.svg" alt="GitHub Repository" class="logo-link" />
              <span>View on GitHub</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .project-wrapper {
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
  }

  .project-header {
    padding: 4rem 1rem 2rem;
    text-align: center;
    border-bottom: 2px solid rgba(93, 213, 255, 0.1);
  }

  .project-header h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
    color: #5DD5FF;
    font-weight: 700;
    letter-spacing: -1px;
  }

  .project-meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    font-size: 1rem;
  }

  .course {
    color: #96F7FF;
    font-weight: 500;
  }

  .date {
    color: #888;
  }

  .project-content {
    padding: 3rem 1rem;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .image-section {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .project-image {
    width: 100%;
    height: auto;
    max-width: 400px;
    border-radius: 12px;
    border: 2px solid rgba(93, 213, 255, 0.2);
    box-shadow: 0 8px 32px rgba(93, 213, 255, 0.1);
    transition: all 0.3s ease;
  }

  .project-image:hover {
    border-color: rgba(93, 213, 255, 0.4);
    box-shadow: 0 12px 48px rgba(93, 213, 255, 0.15);
    transform: translateY(-4px);
  }

  .description-section h2 {
    font-size: 1.75rem;
    color: #5DD5FF;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .description-section p {
    font-size: 1rem;
    color: #c4c4c4;
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .tech-stack {
    margin-bottom: 2rem;
  }

  .tech-stack h3 {
    font-size: 1rem;
    color: #96F7FF;
    margin-bottom: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tag {
    display: inline-block;
    background: rgba(93, 213, 255, 0.1);
    color: #96F7FF;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    border: 1px solid rgba(93, 213, 255, 0.2);
    transition: all 0.2s ease;
  }

  .tag:hover {
    background: rgba(93, 213, 255, 0.15);
    border-color: rgba(93, 213, 255, 0.4);
  }

  .project-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .link-button {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: linear-gradient(135deg, rgba(93, 213, 255, 0.2), rgba(93, 213, 255, 0.05));
    border: 2px solid rgba(93, 213, 255, 0.3);
    color: #5DD5FF;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .link-button:hover {
    background: linear-gradient(135deg, rgba(93, 213, 255, 0.3), rgba(93, 213, 255, 0.1));
    border-color: rgba(93, 213, 255, 0.5);
    color: #96F7FF;
    transform: translateX(4px);
  }

  .logo-link {
    width: 24px;
    height: 24px;
  }
</style>
